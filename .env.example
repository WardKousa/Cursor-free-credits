# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# All values are loaded into JVM system properties at startup by EnvLoader.

# n8n webhook the CRM orchestrator agent listens on.
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/your-id
# Optional shared secret. If set, sent as X-Webhook-Secret on every call.
N8N_WEBHOOK_SECRET=

# ElevenLabs API key (server-side only, never exposed to the browser).
ELEVENLABS_API_KEY=
# Voice id used for text-to-speech (any voice from your ElevenLabs account).
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Speech-to-text model id.
ELEVENLABS_STT_MODEL=scribe_v1
