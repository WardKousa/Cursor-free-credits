# Mapbox public token (pk.eyJ...) — enables the live dark map on the Map page.
# Matches GitHub secret: MAPBOXID
VITE_MAPBOXID=

# n8n webhook URL the frontend uses to fire notifications (new inbox item, resolve, etc.)
# Matches GitHub secret: WEBHOOKURL
VITE_WEBHOOKURL=

# n8n webhook URL for the Gmail integration (incoming email processing).
# Matches GitHub secret: GMAILWEBHOOK
VITE_GMAILWEBHOOK=

# Google Sheets API key for live data sync (Data page).
# Enable "Google Sheets API" in Google Cloud, create an API key, and share
# the sheet as "Anyone with the link". You can also paste the key in-app.
VITE_GOOGLE_SHEETS_API_KEY=

# ElevenLabs TTS for the "Talk" button — speaks the agent's reply in an
# ElevenLabs voice (NOT agent/ConvAI mode; your n8n agent is the brain).
# API KEY is read client-side for the demo (exposed in the browser — move TTS
# server-side for production). Voice id optional (defaults to a standard voice).
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=

# Agent chat endpoint for the "Chat" dropdown — your backend's /api/chat
# (the Fluxzero ChatEndpoint) or an n8n webhook. Can also be set in-app (⚙).
VITE_CHAT_ENDPOINT=

# Gmail inbox (Communications tab) — OAuth *Client ID* only (public, ends in
# .apps.googleusercontent.com). The client SECRET must NOT go here; it is
# server-side only. In Google Cloud → Credentials, add this app's origin to the
# OAuth client's "Authorized JavaScript origins" and add yourself as a test user.
# When unset, Communications falls back to the backend /api/communications.
VITE_GOOGLE_CLIENT_ID=
