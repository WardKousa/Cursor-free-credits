# Mapbox token for the live dark map (Map page).
# Get one free at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# Google Sheets API key for live data sync (Data page).
# Enable "Google Sheets API" in Google Cloud, create an API key, and share
# the sheet as "Anyone with the link". You can also paste the key in-app.
VITE_GOOGLE_SHEETS_API_KEY=

# ElevenLabs Conversational AI agent ID for the voice assistant ("Talk" button).
# Create an agent at https://elevenlabs.io/app/conversational-ai. You can also
# paste the agent ID directly in the Talk panel.
VITE_ELEVENLABS_AGENT_ID=

# Agent chat endpoint for the "Chat" dropdown — your backend's /api/chat
# (the Fluxzero ChatEndpoint) or an n8n webhook. Can also be set in-app (⚙).
VITE_CHAT_ENDPOINT=
